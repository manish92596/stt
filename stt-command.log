# Activate conda environment
conda activate py3.10

# Go to home
cd /home

# Clone inference repo
git clone https://github.com/LATICE-AI/inference.git

# Install ffmpeg
apt-get update && apt-get install -y ffmpeg

# Install PyTorch CUDA 12.4
pip install torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 \
  --index-url https://download.pytorch.org/whl/cu124

# Install base dependencies
pip install \
fastapi \
uvicorn \
huggingface-hub \
pydantic \
python-multipart \
silero-vad \
websockets \
requests \
numpy \
ctranslate2 \
transformers

# Fix setuptools compatibility
pip install "setuptools<70.0.0" setuptools-scm

# Install OpenAI Whisper
pip install --no-build-isolation openai-whisper==20240930

# Install whisper-s2t
pip install --no-build-isolation \
git+https://github.com/LATICE-AI/whisper-s2t.git \
--no-deps

# Install cuDNN
pip install nvidia-cudnn-cu12==9.*

# Fix model path
sed -i 's|/home/inference/models/zero-stt-hinglish-ct2|/home/models/zero-stt-hinglish-ct2|g' \
/home/inference/optimized_api/quota_manager.py

# Create model directory
mkdir -p /home/models

# Convert model to CTranslate2
ct2-transformers-converter \
  --model shunyalabs/zero-stt-hinglish \
  --output_dir /home/models/zero-stt-hinglish-ct2 \
  --quantization float16 \
  --force

# Download tokenizer/config files
cd /home/models/zero-stt-hinglish-ct2

wget https://huggingface.co/shunyalabs/zero-stt-hinglish/resolve/main/tokenizer.json
wget https://huggingface.co/shunyalabs/zero-stt-hinglish/resolve/main/vocab.json
wget https://huggingface.co/shunyalabs/zero-stt-hinglish/resolve/main/merges.txt
wget https://huggingface.co/shunyalabs/zero-stt-hinglish/resolve/main/added_tokens.json
wget https://huggingface.co/shunyalabs/zero-stt-hinglish/resolve/main/special_tokens_map.json
wget https://huggingface.co/shunyalabs/zero-stt-hinglish/resolve/main/preprocessor_config.json

# Kill existing API if running
lsof -ti:6006 | xargs kill -9 2>/dev/null

# Go to inference repo
cd /home/inference

# Export cuDNN path
export LD_LIBRARY_PATH=/root/miniconda3/envs/py3.10/lib/python3.10/site-packages/nvidia/cudnn/lib:$LD_LIBRARY_PATH

# Start API
python optimized_api/main.py













curl -X POST "http://localhost:6006/transcribe" \
  -H "api-key: any-key-works" \
  -H "model-id: /home/models/zero-stt-hinglish-ct2" \
  -H "language: hi" \
  -F "audio_file=@/home/demo.wav"
